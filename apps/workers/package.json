{
  "name": "@locore/workers",
  "version": "0.0.0",
  "private": true,
  "description": "Locore バックグラウンドワーカー（BullMQ + Redis）",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/main.ts",
    "start": "node dist/main.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"(no tests yet)\" && exit 0",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@locore/db": "workspace:*",
    "@locore/shared": "workspace:*",
    "bullmq": "^5.21.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
