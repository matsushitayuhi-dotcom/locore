{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "cd ../.. && pnpm install",
  "buildCommand": "cd ../.. && pnpm turbo run build --filter=@locore/web",
  "outputDirectory": ".next",
  "regions": ["hnd1"],
  "crons": [
    {
      "path": "/api/cron/ai-paris-events",
      "schedule": "0 5 * * *"
    }
  ]
}
