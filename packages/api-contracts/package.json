{
  "name": "@locore/api-contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Locore API 契約: zod スキーマ + OpenAPI 雛形",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./articles": {
      "types": "./src/articles.ts",
      "default": "./src/articles.ts"
    },
    "./users": {
      "types": "./src/users.ts",
      "default": "./src/users.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"(no tests yet)\" && exit 0",
    "clean": "rimraf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@locore/shared": "workspace:*",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3"
  }
}
