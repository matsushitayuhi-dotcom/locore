# Locore DB 環境変数テンプレート
# pnpm --filter @locore/db db:generate / db:migrate / db:seed で使用

# 通常クエリ用（pooler 経由可）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/locore

# マイグレーション用 direct connection
# Supabase の場合: postgres://postgres.[ref]:[pwd]@aws-0-[region].pooler.supabase.com:5432/postgres
# （pooler ではなく直接接続のホストを使う）
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/locore

# Supabase クライアント（バックエンド・フロント側で参照）
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
